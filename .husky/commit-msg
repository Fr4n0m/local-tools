#!/usr/bin/env sh

msg_file="$1"
clean_message=$(sed '/^[[:space:]]*#/d' "$msg_file")

if printf '%s\n' "$clean_message" | grep -Eiq '^[[:space:]]*co-authored-by:'; then
  echo "[commit-policy] Commit blocked: co-author trailers are forbidden."
  exit 1
fi

if printf '%s\n' "$clean_message" | grep -Eiq 'generated by|created by|claude|anthropic|chatgpt|openai|copilot'; then
  echo "[commit-policy] Commit blocked: AI attribution is forbidden."
  exit 1
fi
